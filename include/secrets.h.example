#pragma once

// Copy this file to include/secrets.h (which is gitignored) and fill in.
// If secrets.h is missing or values are empty, the device boots in AP mode
// at SSID "yey-d-setup" (no password) and you can set creds over Serial
// with:   wifi <ssid> <pass>

#define WIFI_SSID  ""
#define WIFI_PASS  ""

// Legacy fallback hostname. New devices default to yey-d-<wifi-sta-mac>.local
// unless a custom id is stored with the `id <name>` command.
#define OTA_HOSTNAME  "yey-d"

// Optional OTA password (empty = no auth). Set for production.
#define OTA_PASSWORD  ""

// UDP log broadcast port. nc -u -l 9999 to watch logs on LAN.
#define UDP_LOG_PORT 9999
