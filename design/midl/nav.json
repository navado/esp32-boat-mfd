{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "nav",
      "title": "Navigation",
      "_note": "screen_nav shows position + COG + SOG + HDG + a compass (5 readouts). square-480 maxTiles=4: modeled as compass + SOG + COG + HDG. navigation.position is dropped from the tiling (it needs a wide lat/lon field that does not fit a square tile).",
      "elements": {
        "compass": {
          "type": "compass",
          "name": "HDG",
          "bindings": {
            "value": { "kind": "signalk", "path": "navigation.headingTrue" }
          },
          "style": { "title": "HDG", "size": 48 },
          "markers": [
            { "id": "COG", "glyph": "chevron_out", "color": "accent", "dir": { "kind": "signalk", "path": "navigation.courseOverGroundTrue" } }
          ]
        },
        "sog": {
          "type": "single-value",
          "name": "SOG",
          "bindings": { "value": { "kind": "signalk", "path": "navigation.speedOverGround" } },
          "format": { "unit": "kn", "decimals": 1 },
          "style": { "title": "SOG", "size": 28 }
        },
        "cog": {
          "type": "single-value",
          "name": "COG",
          "bindings": { "value": { "kind": "signalk", "path": "navigation.courseOverGroundTrue" } },
          "format": { "unit": "deg", "decimals": 0 },
          "style": { "title": "COG", "size": 28 }
        },
        "hdg": {
          "type": "single-value",
          "name": "HDG",
          "bindings": { "value": { "kind": "signalk", "path": "navigation.headingTrue" } },
          "format": { "unit": "deg", "decimals": 0 },
          "style": { "title": "HDG", "size": 28 }
        }
      },
      "layout": {
        "rows": 2,
        "cols": 2,
        "cells": [
          { "element": "compass" },
          { "element": "sog" },
          { "element": "cog" },
          { "element": "hdg" }
        ]
      }
    }
  ]
}
