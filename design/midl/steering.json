{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "steering",
      "title": "Steering",
      "_note": "screen_steering = compass (HDG/CTS) + XTE + VMG + RUDDER + course-trim buttons. square-480 maxTiles=4: modeled as the 2x2 compass/XTE/VMG/RUDDER. The +/- course-trim buttons are dropped from the tiling. VMG binds the firmware path navigation.courseRhumbline.velocityMadeGood (NOT performance.velocityMadeGood).",
      "elements": {
        "compass": {
          "type": "compass",
          "name": "HDG",
          "bindings": { "value": { "kind": "signalk", "path": "navigation.headingTrue" } },
          "style": { "title": "HDG", "size": 48 },
          "markers": [
            { "id": "CTS", "glyph": "diamond", "color": "good", "dir": { "kind": "signalk", "path": "navigation.courseRhumbline.bearingTrackTrue" } }
          ]
        },
        "xte": {
          "type": "single-value",
          "name": "XTE",
          "bindings": { "value": { "kind": "signalk", "path": "navigation.courseRhumbline.crossTrackError" } },
          "format": { "unit": "m", "decimals": 0 },
          "style": { "title": "XTE", "size": 28 }
        },
        "vmg": {
          "type": "single-value",
          "name": "VMG",
          "bindings": { "value": { "kind": "signalk", "path": "navigation.courseRhumbline.velocityMadeGood" } },
          "format": { "unit": "kn", "decimals": 1 },
          "style": { "title": "VMG", "size": 28 }
        },
        "rudder": {
          "type": "single-value",
          "name": "RUDDER",
          "bindings": { "value": { "kind": "signalk", "path": "steering.rudderAngle" } },
          "format": { "unit": "deg", "decimals": 0 },
          "style": { "title": "RUDDER", "size": 28 }
        }
      },
      "layout": {
        "rows": 2,
        "cols": 2,
        "cells": [
          { "element": "compass" },
          { "element": "xte" },
          { "element": "vmg" },
          { "element": "rudder" }
        ]
      }
    }
  ]
}
