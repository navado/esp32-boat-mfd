{
  "midl": "1.0.0",
  "screens": [
    {
      "id": "route",
      "title": "Route",
      "_note": "screen_route shows XTE + BTW + DTW + CTS + VMG (5 readouts). square-480 maxTiles=4: modeled as XTE/DTW/BTW/CTS. VMG (navigation.courseRhumbline.velocityMadeGood) is dropped from the tiling.",
      "elements": {
        "xte": {
          "type": "single-value",
          "name": "XTE",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseRhumbline.crossTrackError"
            }
          },
          "format": {
            "unit": "nm",
            "decimals": 2,
            "side": "port-stbd"
          },
          "style": {
            "title": "XTE",
            "size": 28
          }
        },
        "dtw": {
          "type": "single-value",
          "name": "DTW",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseRhumbline.nextPoint.distance"
            }
          },
          "format": {
            "unit": "nm",
            "decimals": 2
          },
          "style": {
            "title": "DTW",
            "size": 28
          }
        },
        "btw": {
          "type": "single-value",
          "name": "BTW",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseRhumbline.nextPoint.bearingTrue"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "BTW",
            "size": 28
          }
        },
        "cts": {
          "type": "single-value",
          "name": "CTS",
          "bindings": {
            "value": {
              "kind": "signalk",
              "path": "navigation.courseRhumbline.bearingTrackTrue"
            }
          },
          "format": {
            "unit": "deg",
            "decimals": 0
          },
          "style": {
            "title": "CTS",
            "size": 28
          }
        }
      },
      "layout": {
        "rows": 2,
        "cols": 2,
        "cells": [
          {
            "element": "xte"
          },
          {
            "element": "dtw"
          },
          {
            "element": "btw"
          },
          {
            "element": "cts"
          }
        ]
      }
    }
  ]
}
