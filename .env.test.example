# Test environment template.
# Copy to .env.test and fill in your lab values:
#   cp .env.test.example .env.test
#
# .env.test is gitignored (machine-specific). .env.test.local is also
# gitignored and takes precedence for secrets (REMOTE_SUDO_PASS, ESP_LAB_PSK).
#
# Source before running pytest or the demo scripts:
#   set -a; source .env.test; set +a

# --- Remote SignalK host -----------------------------------------------
export REMOTE_HOST="user@nav-server"          # SSH target for make demo-up-remote
export REMOTE_DIR="/home/user/espdisp-signalk"
export SIGNALK_CONTAINER="signalk"            # Docker container name on REMOTE_HOST

# --- SignalK endpoints (reachable from dev laptop + from device) --------
export SK_HOST="192.168.1.100"                # IP of nav-server
export SK_PORT="3000"
export ESPDISP_SK_HOST="${SK_HOST}"
export ESPDISP_SK_PORT="${SK_PORT}"

# --- Device discovery --------------------------------------------------
# mDNS does not cross routed segments; pin the IP dnsmasq leases.
# Check: ssh $REMOTE_HOST 'sudo cat /var/lib/misc/dnsmasq.leases'
export ESPDISP_HOST="10.42.0.67"             # device IP on esp-lab AP
export ESPDISP_BLE_NAME="espdisp"            # BLE advertisement name

# --- Optional auth (leave unset for open devices) ----------------------
# export ESPDISP_OTA_PASSWORD="..."
# export ESPDISP_BASIC_AUTH_USER="admin"
# export ESPDISP_BASIC_AUTH_PASS="..."
